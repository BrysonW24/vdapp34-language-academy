NEXT_PUBLIC_SITE_URL=http://localhost:3000

# All keys below are OPTIONAL. The app runs fully without them (browser Web
# Speech voices + offline conversation coach). Copy this file to .env.local
# (gitignored) and fill in real values to upgrade the experience.

# Premium regional voices (ElevenLabs). When set, each language shows a voice
# picker with region-matched voices and high-quality text-to-speech.
# Get a key at https://elevenlabs.io -> Profile -> API Keys.
ELEVENLABS_API_KEY=
# Optional: override the synthesis model (default: eleven_multilingual_v2).
ELEVENLABS_MODEL=

# Live AI conversation coach (Anthropic Claude). When set, the coach holds a
# free-form conversation; without it, it replays real lesson dialogues.
ANTHROPIC_API_KEY=
# Optional: override the coach model (default: claude-haiku-4-5-20251001).
COACH_MODEL=
