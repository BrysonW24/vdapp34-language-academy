    { "native": "आपकी उम्र क्या है?", "transliteration": "aapki umar kya hai?", "english": "How old are you?", "pronunciation": "AAP-kee OO-mar kyaa hai", "formality": "formal", "tip": "Ask this only when it is socially appropriate." },
