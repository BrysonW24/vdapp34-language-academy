    { "native": "와이파이 비밀번호 뭐예요?", "transliteration": "waipai bimilbeonho mwoyeyo?", "english": "What is the WiFi password?", "pronunciation": "wah-ee-pah-ee bee-meel-bon-hoh mwo-yeh-yo", "formality": "neutral" },
    { "native": "아침 식사 포함이에요?", "transliteration": "achim siksa pohamieyo?", "english": "Is breakfast included?", "pronunciation": "ah-cheem shik-sah poh-hah-mee-eh-yo", "formality": "neutral" },
    { "native": "수건 좀 더 주세요", "transliteration": "sugeon jom deo juseyo", "english": "Please bring more towels", "pronunciation": "soo-gon jom do joo-seh-yo", "formality": "neutral" },
    { "native": "방 키를 잃어버렸어요", "transliteration": "bang kireul ireobeoryeosseoyo", "english": "I lost my room key", "pronunciation": "bahng kee-reul ee-ro-bo-ryo-sso-yo", "formality": "neutral" },
