    { "native": "Paumanhin po", "english": "Excuse me / Sorry", "pronunciation": "pa-oo-MAN-hin po", "formality": "formal", "tip": "The everyday spoken version is pasensya na po." },
    { "native": "Oo / Hindi", "english": "Yes / No", "pronunciation": "OH-oh / hin-DEE", "formality": "neutral", "tip": "Polite yes is opo; polite no is hindi po." },
    { "native": "Hindi ko maintindihan", "english": "I don't understand", "pronunciation": "hin-DEE ko ma-in-tin-DEE-han", "formality": "neutral", "tip": "The single most useful survival phrase." },
    { "native": "Marunong ka ba ng Ingles?", "english": "Do you speak English?", "pronunciation": "ma-ROO-nong ka ba nang ing-LES", "formality": "informal", "tip": "Most Filipinos speak some English, so this opens many doors." },
    { "native": "Pwede po bang ulitin?", "english": "Can you repeat that?", "pronunciation": "PWE-de po bang oo-LEE-tin", "formality": "formal" },
