    { "native": "Kailangan ko ng tulong", "english": "I need help", "pronunciation": "ka-ee-LA-ngan ko nang TOO-long", "formality": "neutral" },
    { "native": "Paalam po", "english": "Goodbye", "pronunciation": "pa-A-lam po", "formality": "formal", "tip": "Casual: sige, often paired with a wave or bye." }
