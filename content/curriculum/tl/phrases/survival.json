  "phrases": [
    { "native": "Kumusta po", "english": "Hello / How are you", "pronunciation": "koo-moos-TA po", "formality": "formal", "tip": "Adding po makes it polite. Drop it with close friends: kumusta." },
    { "native": "Salamat po", "english": "Thank you", "pronunciation": "sa-LA-mat po", "formality": "formal", "tip": "Reply with walang anuman (you're welcome)." },
